{
  "$schema": "https://opencode.ai/config.json",
  "model": "alibaba-coding-plan-cn/glm-5",
  "small_model": "github-copilot/gpt-5-mini",
  "disabled_providers": ["google", "anthropic", "opencode", "openrouter"],
  "default_agent": "plan",
  "share": "disabled",
  "provider": {
    "google": {
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}"
      }
    },
    "openai": {
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}"
      }
    },
    "anthropic": {
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}"
      }
    }
  },
  "permission": {
    "plan*": "deny",
    "doom_loop": "ask",
    "external_directory": "ask",
    "context7*": "allow",
    "brave*": "allow",
    "delegate": "deny"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    // "cloudflare": {
    //   "type": "remote",
    //   "url": "https://mcp.cloudflare.com/mcp"
    // },
    "brave": {
      "type": "local",
      "command": ["bunx", "@brave/brave-search-mcp-server", "--enabled-tools", "brave_web_search"]
    }
  }
}
