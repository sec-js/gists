{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.6",
  "small_model": "opencode/gpt-5-nano",
  "disabled_providers": ["cloudflare-ai-gateway"],
  "default_agent": "plan",
  "share": "disabled",
  "compaction": {
    "auto": false
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}"
      }
    },
    "anthropic": {
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}"
      }
    }
  },
  "agent": {
    "explore": {
      "description": "Read-only agent backed by a cheap model. Use it for simple and focused exploring tasks.",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "general": {
      "description": "General-purpose subagent with write permission."
    }
  },
  "permission": {
    "plan*": "deny",
    "todo*": "deny",
    "question": "deny",
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow",
      "/root/.config/opencode/**": "allow"
    },
    "context7*": "allow",
    "brave*": "allow",
    "markitdown*": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "brave": {
      "type": "local",
      "command": ["bunx", "@brave/brave-search-mcp-server", "--enabled-tools", "brave_web_search"]
    },
    "markitdown": {
      "type": "local",
      "command": ["uvx", "markitdown-mcp"]
    }
  }
}
