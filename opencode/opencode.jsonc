{
  "$schema": "https://opencode.ai/config.json",
  "model": "openai/gpt-5.4",
  "small_model": "google/gemini-flash-lite-latest",
  "disabled_providers": ["ollama-cloud", "openrouter", "cloudflare-ai-gateway" ],
  "default_agent": "plan",
  "autoupdate": false,
  "share": "disabled",
  "compaction": {
    "auto": false
  },
  "provider": {
    "yunwu-codex": {
      "npm": "@ai-sdk/openai",
      "name": "Yunwu Codex",
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}",
        "setCacheKey": true
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "cost": { "input": 2.5, "output": 15, "cache_read": 0.25 },
          "limit": { "context": 400000, "input": 272000, "output": 128000 },
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image", "pdf"] }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 mini",
          "cost": { "input": 0.75, "output": 4.5, "cache_read": 0.075 },
          "limit": { "context": 400000, "input": 272000, "output": 128000 },
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image"] }
        },
        "gpt-5.5": {
          "name": "GPT-5.5",
          "cost": { "input": 5, "output": 30, "cache_read": 0.5 },
          "limit": { "context": 400000, "input": 272000, "output": 128000 },
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image", "pdf"] }
        }
      }
    },
    "cr-codex": {
      "npm": "@ai-sdk/openai",
      "name": "CR Codex",
      "options": {
        "baseURL": "https://cdn.coderelay.cn/v1",
        "apiKey": "{env:CR_CODEX_API_KEY}",
        "setCacheKey": true
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "cost": { "input": 2.5, "output": 15, "cache_read": 0.25 },
          "limit": { "context": 400000, "input": 272000, "output": 128000 },
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image", "pdf"] }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 mini",
          "cost": { "input": 0.75, "output": 4.5, "cache_read": 0.075 },
          "limit": { "context": 400000, "input": 272000, "output": 128000 },
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image"] }
        },
        "gpt-5.5": {
          "name": "GPT-5.5",
          "cost": { "input": 5, "output": 30, "cache_read": 0.5 },
          "limit": { "context": 400000, "input": 272000, "output": 128000 },
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image", "pdf"] }
        }
      }
    },
    "cr-codex-plus": {
      "npm": "@ai-sdk/openai",
      "name": "CR Codex Plus",
      "options": {
        "baseURL": "https://cdn.coderelay.cn/v1",
        "apiKey": "{env:CR_CODEX_PLUS_API_KEY}",
        "setCacheKey": true
      },
      "models": {
        "gpt-5.4": {
          "name": "GPT-5.4",
          "cost": { "input": 2.5, "output": 15, "cache_read": 0.25 },
          "limit": { "context": 400000, "input": 272000, "output": 128000 },
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image", "pdf"] }
        },
        "gpt-5.4-mini": {
          "name": "GPT-5.4 mini",
          "cost": { "input": 0.75, "output": 4.5, "cache_read": 0.075 },
          "limit": { "context": 400000, "input": 272000, "output": 128000 },
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image"] }
        },
        "gpt-5.5": {
          "name": "GPT-5.5",
          "cost": { "input": 5, "output": 30, "cache_read": 0.5 },
          "limit": { "context": 400000, "input": 272000, "output": 128000 },
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image", "pdf"] }
        }
      }
    },
    "yunwu-claude": {
      "npm": "@ai-sdk/anthropic",
      "name": "Yunwu Claude",
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}"
      },
      "models": {
        "claude-opus-4-6": {
          "name": "Claude Opus 4.6",
          "cost": { "input": 5, "output": 25, "cache_read": 0.5, "cache_write": 6.25 },
          "limit": { "context": 200000, "output": 64000 },
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image", "pdf"] }
        },
        "claude-opus-4-8": {
          "name": "Claude Opus 4.8",
          "cost": { "input": 5, "output": 25, "cache_read": 0.5, "cache_write": 6.25 },
          "limit": { "context": 200000, "output": 64000 },
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image", "pdf"] }
        },
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6",
          "cost": { "input": 3, "output": 15, "cache_read": 0.3, "cache_write": 3.75 },
          "limit": { "context": 200000, "output": 64000 },
          "reasoning": true,
          "attachment": true,
          "modalities": { "input": ["text", "image", "pdf"] }
        }
      }
    }
  },
  "agent": {
    "explore": {
      "description": "Read-only agent backed by a cheap model.",
      "model": "openai/gpt-5.4-mini"
    },
    "general": {
      "description": "General-purpose subagent with write permission."
    }
  },
  "permission": {
    "plan*": "deny",
    "todo*": "deny",
    "question": "deny",
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow",
      "/root/.config/opencode/**": "allow",
      "/var/www/vibe/tmp/**": "allow"
    },
    "brave*": "allow",
    "markitdown*": "allow"
  },
  "mcp": {
    "brave": {
      "type": "local",
      "command": [
        "npx",
        "@brave/brave-search-mcp-server",
        "--enabled-tools",
        "brave_web_search"
      ]
    },
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp"
      ],
      "timeout": 300000
    }
  }
}
