{
  "$schema": "https://opencode.ai/config.json",
  "model": "github-copilot/gpt-5.4-mini",
  "small_model": "ollama-cloud/gpt-oss:20b",
  "disabled_providers": ["openrouter", "nvidia", "cloudflare-ai-gateway"],
  "default_agent": "plan",
  "autoupdate": false,
  "share": "disabled",
  "compaction": {
    "auto": false
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}"
      }
    },
    "anthropic": {
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}"
      }
    },
    "google": {
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}"
      }
    }
  },
  "agent": {
    "explore": {
      "description": "Read-only agent backed by a cheap model."
    },
    "general": {
      "description": "General-purpose subagent with write permission."
    }
  },
  "permission": {
    "plan*": "deny",
    "todo*": "deny",
    "question": "deny",
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow",
      "/root/.config/opencode/**": "allow"
    },
    "skill": {
      "*": "allow",
      "customize-opencode": "deny"
    },
    "context7*": "allow",
    "brave*": "allow",
    "markitdown*": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "brave": {
      "type": "local",
      "command": ["npx", "@brave/brave-search-mcp-server", "--enabled-tools", "brave_web_search"]
    },
    "gmail": {
      "enabled": false,
      "type": "remote",
      "url": "https://gmailmcp.googleapis.com/mcp/v1"
    },
    "markitdown": {
      "type": "local",
      "command": ["uvx", "markitdown-mcp"],
      "timeout": 300000
    }
  }
}
