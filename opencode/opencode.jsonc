{
  "$schema": "https://opencode.ai/config.json",
  "model": "nano-gpt/deepseek/deepseek-v4-pro-cheaper:thinking",
  "small_model": "ollama-cloud/gpt-oss:20b",
  "disabled_providers": ["opencode", "openrouter", "nvidia", "cloudflare-ai-gateway"],
  "default_agent": "plan",
  "share": "disabled",
  "compaction": {
    "auto": false
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}"
      }
    },
    "nano-gpt": {
      "models": {
        "deepseek/deepseek-v4-pro-cheaper:thinking": {
          "name": "DeepSeek V4 Pro Thinking",
          "limit": {
            "context": 1000000,
            "output": 384000
          },
          "options": {
            "reasoningEffort": "max"
          }
        }
      }
    }
  },
  "agent": {
    "explore": {
      "description": "Read-only agent backed by a cheap model.",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "general": {
      "description": "General-purpose subagent with write permission."
    }
  },
  "permission": {
    "plan*": "deny",
    "todo*": "deny",
    "question": "deny",
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow",
      "/root/.config/opencode/**": "allow"
    },
    "context7*": "allow",
    "brave*": "allow",
    "markitdown*": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "brave": {
      "type": "local",
      "command": ["npx", "@brave/brave-search-mcp-server", "--enabled-tools", "brave_web_search"]
    },
    "markitdown": {
      "type": "local",
      "command": ["uvx", "markitdown-mcp"],
      "timeout": 300000
    }
  }
}
