{
  "$schema": "https://opencode.ai/config.json",
  "model": "opencode-go/kimi-k2.6",
  "small_model": "ollama-cloud/gpt-oss:20b",
  "disabled_providers": [
    "openrouter",
    "nvidia",
    "cloudflare-ai-gateway"
  ],
  "default_agent": "plan",
  "autoupdate": false,
  "share": "disabled",
  "compaction": {
    "auto": false
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}"
      }
    },
    "anthropic": {
      "options": {
        "baseURL": "https://yunwu.ai/v1",
        "apiKey": "{env:YUNWU_API_KEY}"
      }
    },
    "cursor-acp": {
      "name": "Cursor",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://127.0.0.1:32124/v1"
      },
      "models": {
        "composer-2.5": {
          "name": "Composer 2.5",
          "options": {
            "cursorModel": "composer-2.5"
          },
          "variants": {
            "fast": {
              "cursorModel": "composer-2.5-fast"
            }
          }
        },
        "claude-opus-4-8": {
          "name": "Claude Opus 4 8",
          "options": {
            "cursorModel": "claude-opus-4-8-medium"
          },
          "variants": {
            "low": {
              "cursorModel": "claude-opus-4-8-low"
            },
            "low-fast": {
              "cursorModel": "claude-opus-4-8-low-fast"
            },
            "medium": {
              "cursorModel": "claude-opus-4-8-medium"
            },
            "medium-fast": {
              "cursorModel": "claude-opus-4-8-medium-fast"
            },
            "high": {
              "cursorModel": "claude-opus-4-8-high"
            },
            "high-fast": {
              "cursorModel": "claude-opus-4-8-high-fast"
            },
            "xhigh": {
              "cursorModel": "claude-opus-4-8-xhigh"
            },
            "xhigh-fast": {
              "cursorModel": "claude-opus-4-8-xhigh-fast"
            },
            "max": {
              "cursorModel": "claude-opus-4-8-max"
            },
            "thinking-low": {
              "cursorModel": "claude-opus-4-8-thinking-low"
            },
            "thinking-medium": {
              "cursorModel": "claude-opus-4-8-thinking-medium"
            },
            "thinking-high": {
              "cursorModel": "claude-opus-4-8-thinking-high"
            },
            "thinking-high-fast": {
              "cursorModel": "claude-opus-4-8-thinking-high-fast"
            },
            "thinking-xhigh": {
              "cursorModel": "claude-opus-4-8-thinking-xhigh"
            },
            "thinking-max": {
              "cursorModel": "claude-opus-4-8-thinking-max"
            },
            "max-fast": {
              "cursorModel": "claude-opus-4-8-max-fast"
            },
            "thinking-low-fast": {
              "cursorModel": "claude-opus-4-8-thinking-low-fast"
            },
            "thinking-max-fast": {
              "cursorModel": "claude-opus-4-8-thinking-max-fast"
            },
            "thinking-medium-fast": {
              "cursorModel": "claude-opus-4-8-thinking-medium-fast"
            },
            "thinking-xhigh-fast": {
              "cursorModel": "claude-opus-4-8-thinking-xhigh-fast"
            }
          }
        },
        "gpt-5.5": {
          "name": "GPT 5.5",
          "options": {
            "cursorModel": "gpt-5.5-medium"
          },
          "variants": {
            "none": {
              "cursorModel": "gpt-5.5-none",
              "cost": {
                "input": 5,
                "output": 30,
                "cache_read": 0.5,
                "cache_write": 5,
                "context_over_200k": {
                  "input": 10,
                  "output": 45,
                  "cache_read": 1,
                  "cache_write": 10
                }
              }
            },
            "low": {
              "cursorModel": "gpt-5.5-low",
              "cost": {
                "input": 5,
                "output": 30,
                "cache_read": 0.5,
                "cache_write": 5,
                "context_over_200k": {
                  "input": 10,
                  "output": 45,
                  "cache_read": 1,
                  "cache_write": 10
                }
              }
            },
            "low-fast": {
              "cursorModel": "gpt-5.5-low-fast",
              "cost": {
                "input": 5,
                "output": 30,
                "cache_read": 0.5,
                "cache_write": 5,
                "context_over_200k": {
                  "input": 10,
                  "output": 45,
                  "cache_read": 1,
                  "cache_write": 10
                }
              }
            },
            "medium": {
              "cursorModel": "gpt-5.5-medium",
              "cost": {
                "input": 5,
                "output": 30,
                "cache_read": 0.5,
                "cache_write": 5,
                "context_over_200k": {
                  "input": 10,
                  "output": 45,
                  "cache_read": 1,
                  "cache_write": 10
                }
              }
            },
            "medium-fast": {
              "cursorModel": "gpt-5.5-medium-fast",
              "cost": {
                "input": 5,
                "output": 30,
                "cache_read": 0.5,
                "cache_write": 5,
                "context_over_200k": {
                  "input": 10,
                  "output": 45,
                  "cache_read": 1,
                  "cache_write": 10
                }
              }
            },
            "high": {
              "cursorModel": "gpt-5.5-high",
              "cost": {
                "input": 5,
                "output": 30,
                "cache_read": 0.5,
                "cache_write": 5,
                "context_over_200k": {
                  "input": 10,
                  "output": 45,
                  "cache_read": 1,
                  "cache_write": 10
                }
              }
            },
            "high-fast": {
              "cursorModel": "gpt-5.5-high-fast",
              "cost": {
                "input": 5,
                "output": 30,
                "cache_read": 0.5,
                "cache_write": 5,
                "context_over_200k": {
                  "input": 10,
                  "output": 45,
                  "cache_read": 1,
                  "cache_write": 10
                }
              }
            },
            "extra-high": {
              "cursorModel": "gpt-5.5-extra-high",
              "cost": {
                "input": 5,
                "output": 30,
                "cache_read": 0.5,
                "cache_write": 5,
                "context_over_200k": {
                  "input": 10,
                  "output": 45,
                  "cache_read": 1,
                  "cache_write": 10
                }
              }
            },
            "extra-high-fast": {
              "cursorModel": "gpt-5.5-extra-high-fast",
              "cost": {
                "input": 5,
                "output": 30,
                "cache_read": 0.5,
                "cache_write": 5,
                "context_over_200k": {
                  "input": 10,
                  "output": 45,
                  "cache_read": 1,
                  "cache_write": 10
                }
              }
            },
            "none-fast": {
              "cursorModel": "gpt-5.5-none-fast",
              "cost": {
                "input": 5,
                "output": 30,
                "cache_read": 0.5,
                "cache_write": 5,
                "context_over_200k": {
                  "input": 10,
                  "output": 45,
                  "cache_read": 1,
                  "cache_write": 10
                }
              }
            }
          },
          "cost": {
            "input": 5,
            "output": 30,
            "cache_read": 0.5,
            "cache_write": 5,
            "context_over_200k": {
              "input": 10,
              "output": 45,
              "cache_read": 1,
              "cache_write": 10
            }
          }
        },
        "auto": {
          "name": "Auto",
          "cost": {
            "input": 1.25,
            "output": 6,
            "cache_read": 0.25,
            "cache_write": 1.25
          }
        }
      }
    }
  },
  "agent": {
    "explore": {
      "description": "Read-only agent backed by a cheap model.",
      "model": "opencode-go/deepseek-v4-flash"
    },
    "general": {
      "description": "General-purpose subagent with write permission."
    }
  },
  "permission": {
    "plan*": "deny",
    "todo*": "deny",
    "question": "deny",
    "external_directory": {
      "*": "ask",
      "/tmp/**": "allow",
      "/root/.config/opencode/**": "allow"
    },
    "context7*": "allow",
    "brave*": "allow",
    "markitdown*": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    },
    "brave": {
      "type": "local",
      "command": [
        "npx",
        "@brave/brave-search-mcp-server",
        "--enabled-tools",
        "brave_web_search"
      ]
    },
    "markitdown": {
      "type": "local",
      "command": [
        "uvx",
        "markitdown-mcp"
      ],
      "timeout": 300000
    },
    "gmail": {
      "enabled": false,
      "type": "remote",
      "url": "https://gmailmcp.googleapis.com/mcp/v1",
      "oauth": {
        "clientId": "{env:GMAIL_CLIENT_ID}",
        "clientSecret": "{env:GMAIL_CLIENT_SECRET}"
      }
    }
  },
  "plugin": [
    "@rama_nigg/open-cursor@latest"
  ]
}
